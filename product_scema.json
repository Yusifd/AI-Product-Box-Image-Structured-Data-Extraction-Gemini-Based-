{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductExtractionSchema",
  "type": "object",
  "required": [
    "name",
    "brand",
    "category",
    "description",
    "manufacturing_country",
    "estimated_wholesale_price_azn",
    "estimated_retail_price_azn",
    "confidence_score"
  ],
  "properties": {
    "name": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 255
    },
    "brand": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 255
    },
    "category": {
      "type": [
        "string",
        "null"
      ]
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1000
    },
    "manufacturing_country": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 255
    },
    "estimated_wholesale_price_azn": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "estimated_retail_price_azn": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1

    }
  }
}